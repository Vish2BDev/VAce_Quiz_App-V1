# .env.example — copy to .env for local development (never commit .env)
# ----------------------------------------------------------------
# Flask
# ----------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-hex-string

# Optional: set to 'true' to enable Flask debug mode locally
FLASK_DEBUG=false

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------
# Leave unset locally to use SQLite (quiz_master.db).
# For Supabase, paste the "Transaction pooler" URL from:
#   Supabase Dashboard → Project → Settings → Database → Connection string
#
# Direct connection (lower latency, higher connection count):
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Pooler / pgBouncer (recommended for Vercel serverless):
#   DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
DATABASE_URL=
